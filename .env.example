# ──────────────────────────────────────────────────────────────────────────
# Benzo environment — copy to `.env` and fill in.
# .env is gitignored; never commit real secrets. Fuji TEST keys only —
# never reuse a key that holds mainnet funds.
# ──────────────────────────────────────────────────────────────────────────

# Avalanche Fuji C-Chain (chain id 43113)
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Deployer / primary test wallet (0x-prefixed private key).
# Fund with test AVAX: https://core.app/tools/testnet-faucet/?subnet=c&token=c
# (coupon `avalanche-academy`) or the Builder Hub login faucet.
PRIVATE_KEY=

# Second test wallet — used as the counterparty for private-transfer flows
# and as the auditor key in local testing.
PRIVATE_KEY_2=

# Optional gas floor for private gift ephemeral wallets. The default 0.02 AVAX
# covers both ephemeral eERC registration and the final private-transfer sweep
# on Fuji; raise it if live gas costs increase.
PRIVATE_GIFT_MIN_EPHEMERAL_AVAX=0.02

# Contract verification on testnet.snowtrace.io goes through Routescan and
# needs no real API key — hardhat-verify is configured with a placeholder.

# --- M4 testing tiers (testnet-only; see README "Testing") ---
# TIER 1 Fuji-fork integration tests are fundless and need no keys: FORK=fuji.
# Optionally pin the fork block for reproducibility.
FORK=
FUJI_FORK_BLOCK=

# TIER 2 funded live-testnet suites (@benzo/e2e). Everything self-skips unless
# RUN_LIVE_E2E=1, so these are safe to leave blank locally and in PR CI.
RUN_LIVE_E2E=
BENZO_E2E_TARGET=fuji
# Funded testnet accounts (Fuji test keys ONLY — never mainnet funds).
BENZO_ONRAMP_USER_KEY=
BENZO_RELAYER_KEY=
BENZO_DEPLOYER_KEY=
# Live API base URL for the disclosure/payroll suites (optional; those suites
# self-skip when unset).
BENZO_API_BASE_URL=
# Optional per-network RPC overrides (default to the public Fuji/BenzoNet RPCs).
BENZO_E2E_FUJI_RPC_URL=
BENZO_E2E_BENZONET_RPC_URL=
