{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
	"files": {
		"includes": [
			"packages/**/src/**/*.ts",
			"infra/scripts/**/*.ts",
			"services/**/src/**/*.ts",
			"services/**/test/**/*.ts",
			"services/**/*.config.ts",
			"tests/**/src/**/*.ts",
			"tests/**/fixtures/**/*.ts",
			"tests/**/suites/**/*.ts",
			"tests/**/*.config.ts"
		]
	},
	"formatter": { "enabled": false },
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"suspicious": {
				"noExplicitAny": "off"
			},
			"style": {
				"noNonNullAssertion": "off",
				"useTemplate": "off"
			},
			"complexity": {
				"useOptionalChain": "off"
			}
		}
	}
}
