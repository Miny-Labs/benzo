{
  "name": "@benzo/api",
  "private": true,
  "version": "0.1.0",
  "description": "Benzo off-chain API service",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "dev": "tsx watch src/index.ts",
    "index:backfill": "tsx src/indexer/backfill.ts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/rate-limit": "^11.1.0",
    "@zk-kit/baby-jubjub": "^1.0.3",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "maci-crypto": "^2.0.0",
    "pg": "^8.22.0",
    "pg-boss": "^12.25.1",
    "pino": "^10.3.1",
    "poseidon-lite": "^0.3.0",
    "snarkjs": "^0.7.5",
    "viem": "^2.54.4",
    "web-worker": "^1.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.4",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
