# ──────────────────────────────────────────────────────────────────────────
# Benzo API — PRODUCTION tier template. Copy to `.env` for a mainnet deploy.
# .env is gitignored; never commit real secrets.
#
# Production runs on Avalanche C-Chain mainnet (CHAIN_ENV=avalanche, chain id
# 43114 → NETWORK_TIER derives tier=production). The config guards REFUSE to
# boot when NODE_ENV=production targets a staging-tier network, when a
# production tier is pointed at a testnet chain id / RPC host, or when
# DATABASE_URL is an obviously-local database.
#
# The mainnet cutover is intentionally a config + env change: flip CHAIN_ENV
# to avalanche, set the chain id / RPC / secrets below, and ship an
# avalanche deployment manifest at contracts/deployments/avalanche.json.
#
# IMPORTANT: sealed DB rows are bound to APP_MASTER_KEY. Production and staging
# MUST use SEPARATE APP_MASTER_KEY values AND SEPARATE DATABASE_URLs. The
# production master key must be custodied separately and never reused in
# staging or local development.
# ──────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# Network / tier — Avalanche C-Chain mainnet (production tier).
CHAIN_ENV=avalanche
BENZONET_CHAIN_ID=43114
# Required for production — must be a mainnet RPC (testnet hosts are rejected).
BENZONET_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Public origin the API is served from (required when NODE_ENV=production).
API_DOMAIN=api.benzo.space

# PRODUCTION master key — 32-byte hex. DISTINCT from staging. Custody securely.
# Replace this placeholder via your secret manager; NEVER commit the real key.
APP_MASTER_KEY=REPLACE_WITH_PRODUCTION_MASTER_KEY_32_BYTE_HEX

# PRODUCTION ops signer — 0x-prefixed private key. DISTINCT from staging.
# Replace via your secret manager; NEVER commit the real key.
OPS_PRIVATE_KEY=REPLACE_WITH_PRODUCTION_OPS_PRIVATE_KEY

# PRODUCTION database — its own Postgres, never shared with staging. A local
# host (localhost/127.0.0.1) is rejected in production.
DATABASE_URL=postgres://benzo:REPLACE_WITH_PRODUCTION_DB_PASSWORD@prod-db.internal:5432/benzo_production

# eERC addresses resolve from the deployment manifest
# (contracts/deployments/avalanche.json) when present. The DEPLOYED image is built
# from services/api and does NOT bundle that directory, so set the mainnet converter
# + registrar explicitly here after the mainnet deploy (an absent manifest boots
# fine as long as these are provided; the config refuses to boot if an address is
# resolvable from NEITHER the manifest nor these overrides).
# Left unset on purpose: with no mainnet manifest and these unset, the config
# fails fast (eerc_*_unresolved) rather than booting against a wrong address —
# fill in every manifest-derived runtime address after the C-Chain deploy.
# EERC_ENCRYPTED_ERC_ADDRESS=0x...
# EERC_REGISTRAR_ADDRESS=0x...
# HANDLE_REGISTRY_ADDRESS=0x...  # or handle lookups run as if none is deployed
# PAYROLL_TOKEN_ID defaults to the manifest USDC tokenId; override only if needed.
# PAYROLL_TOKEN_ID=1
