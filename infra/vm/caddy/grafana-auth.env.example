# Caddy basic_auth credentials for Grafana — copy to caddy/grafana-auth.env
# (gitignored) and put the real hash here, isolated from the main .env.
#
# IMPORTANT: docker compose interpolates env_file values, so every '$' in a
# bcrypt hash MUST be doubled to '$$'. Compose collapses '$$' -> '$' when it
# passes the value to Caddy, so Caddy receives the correct hash.
#
# Generate:  docker run --rm caddy caddy hash-password --plaintext '<pw>'
# then double every '$'. The placeholder below is the Caddy-docs example hash
# (already '$$'-escaped) — REPLACE it.
GRAFANA_BASIC_AUTH_HASH=$$2a$$14$$Zkx19XLiW6VYouLHR5NmfOFU0z2GTNmpkT/5qqR7hx4IjWJPDhjvG
