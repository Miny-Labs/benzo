# BenzoNet VM edge config. Copy to infra/vm/.env and fill in. NEVER commit .env.
#
# --- chain identity ---
# subnetID from `avalanche blockchain describe benzonet` (rename the file in
# configs/subnets/ to match it, and set allowedNodes to the rpc-node's NodeID).
SUBNET_ID=
# BenzoNet blockchain ID (stable).
BLOCKCHAIN_ID=21iisL1nkpM2AauUadAz7p1gK3waRBZLEJme3LU3gsWpaxy792

# --- public edge (Caddy) ---
# DNS A-record must point rpc.benzonet.<domain> at this VM before first boot
# (Let's Encrypt HTTP-01). See README.
RPC_DOMAIN=rpc.benzonet.example.com
ACME_EMAIL=ops@example.com

# Per-app path tokens — generate each with:  openssl rand -hex 32
# These are abuse-throttling identifiers shipped in browser bundles, NOT secrets.
WALLET_RPC_TOKEN=
CONSOLE_RPC_TOKEN=
BACKEND_RPC_TOKEN=

# Allowed browser origins for CORS (exact scheme + host [+ :port]).
WALLET_ORIGIN=https://wallet.benzo.example.com
CONSOLE_ORIGIN=https://console.benzo.example.com

# --- grafana (only used with --profile monitoring, #28) ---
GF_SECURITY_ADMIN_PASSWORD=
