# BenzoNet VM edge config. Copy to infra/vm/.env and fill in. NEVER commit .env.
# Keys are alphabetized (dotenv-linter). Grouping notes are in the comments.

# Let's Encrypt contact for the public edge.
ACME_EMAIL=ops@example.com
# Per-app path token (openssl rand -hex 32) — abuse identifier, not a secret.
BACKEND_RPC_TOKEN=
# BenzoNet blockchain ID (stable).
BLOCKCHAIN_ID=21iisL1nkpM2AauUadAz7p1gK3waRBZLEJme3LU3gsWpaxy792
# Allowed browser origin for the console app (exact scheme + host [+ :port]).
CONSOLE_ORIGIN=https://console.benzo.example.com
CONSOLE_RPC_TOKEN=
# Local dev origin for CORS. Leave UNSET in production — when unset the Caddy
# rules fall back to a value that never matches a real browser Origin.
DEV_ORIGIN=
# --- monitoring profile (#28); the placeholders keep Caddy parsing when
#     monitoring is not deployed (grafana.localhost uses an internal cert). ---
# Grafana admin password.
GF_SECURITY_ADMIN_PASSWORD=
# Grafana's own root URL (behind Caddy). Set to https://<GRAFANA_DOMAIN>.
GF_SERVER_ROOT_URL=https://grafana.localhost
# NOTE: the Caddy basic_auth bcrypt hash lives in caddy/grafana-auth.env (a
# separate env_file) — bcrypt hashes contain '$' which compose would mangle if
# they sat in this interpolated file. See caddy/grafana-auth.env.example.
# Public host for Grafana (add a DNS A-record when you deploy monitoring).
GRAFANA_DOMAIN=grafana.localhost
# Caddy basic_auth username.
GRAFANA_USER=admin
# DNS A-record must point this at the VM before first boot (Let's Encrypt HTTP-01).
RPC_DOMAIN=rpc.benzonet.example.com
# subnetID from `avalanche blockchain describe benzonet` (also rename the file in
# configs/subnets/ to match it and set allowedNodes to the rpc-node's NodeID).
SUBNET_ID=
# Allowed browser origin for the wallet app.
WALLET_ORIGIN=https://wallet.benzo.example.com
WALLET_RPC_TOKEN=
